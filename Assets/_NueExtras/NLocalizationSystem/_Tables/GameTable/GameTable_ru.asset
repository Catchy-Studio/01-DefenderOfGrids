      m_Items: []
  - m_Id: 362105380786176
    m_Localized: "\u0421\u043F\u043B\u043E\u0448\u043D\u043E\u0439 \u0448\u0430\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 9319380144128
    m_Localized: <TARGET_SCORE>
    m_Metadata:
      m_Items: []
  - m_Id: 9328754413568
    m_Localized: "\u0427\u0442\u043E\u0431\u044B \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C
      \u0442\u0435\u043A\u0443\u0449\u0438\u0439 \u0441\u0442\u043E\u043B, \u043D\u0443\u0436\u043D\u043E
      \u043D\u0430\u0431\u0440\u0430\u0442\u044C \u044D\u0442\u043E\u0442 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
      <POINT>."
    m_Metadata:
      m_Items: []
  - m_Id: 19319620096000
    m_Localized: <CURRENT_SCORE>
    m_Metadata:
      m_Items: []
  - m_Id: 19435332554752
    m_Localized: "\u0412\u0441\u0435\u0433\u043E \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043E
      <POINT> \u0432 \u044D\u0442\u043E\u043C \u0441\u0442\u043E\u043B\u0435. \u0414\u043B\u044F
      \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F \u043D\u0443\u0436\u043D\u043E
      \u043D\u0430\u0431\u0440\u0430\u0442\u044C <TARGET_SCORE>."
    m_Metadata:
      m_Items: []
  - m_Id: 19723498016768
    m_Localized: <MULT>
    m_Metadata:
      m_Items: []
  - m_Id: 19918201802752
    m_Localized: "\u041F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u0443\u0435\u0442
      <TURN_SCORE> \u0432 <CURRENT_SCORE>, \u0443\u043C\u043D\u043E\u0436\u0430\u044F
      \u043D\u0430 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 <MULT>."
    m_Metadata:
      m_Items: []
  - m_Id: 19974770380800
    m_Localized: <TURN_SCORE>
    m_Metadata:
      m_Items: []
  - m_Id: 20075035217920
    m_Localized: "\u0421\u0443\u043C\u043C\u0430 <POINT>, \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u0430\u044F
      \u0437\u0430 \u0445\u043E\u0434. \u0421\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u043F\u0440\u0438 <ON_TURN_START>."
    m_Metadata:
      m_Items: []
  - m_Id: 20175719485440
    m_Localized: "\u041C\u043E\u043D\u0435\u0442\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 20244459933696
    m_Localized: "\u0426\u0435\u043D\u043D\u044B\u0439 \u0440\u0435\u0441\u0443\u0440\u0441.
      \u0418\u043C\u0435\u0435\u0442 <INTEREST>."
    m_Metadata:
      m_Items: []
  - m_Id: 20325019930624
    m_Localized: <SHOT>
    m_Metadata:
      m_Items: []
  - m_Id: 20399791788032
    m_Localized: "\u041E\u0441\u0442\u0430\u0432\u0448\u0435\u0435\u0441\u044F \u0447\u0438\u0441\u043B\u043E
      <SHOT>. \u0415\u0441\u043B\u0438 <SHOT> \u0441\u0442\u0430\u043D\u0435\u0442
      0 \u0438 \u0432\u044B \u043D\u0435 \u043F\u0440\u0435\u0432\u044B\u0441\u0438\u0442\u0435
      <TARGET_SCORE>, \u0432\u044B <FAILED>."
    m_Metadata:
      m_Items: []
