      m_Items: []
  - m_Id: 703824253145088
    m_Localized: "\u4F60\u5DF2\u964D\u7EA7\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 704224020647936
    m_Localized: "\u76EE\u6807"
    m_Metadata:
      m_Items: []
  - m_Id: 704224863703040
    m_Localized: "- \u5C06 <STICKER> \u62D6\u653E\u5230\u4EFB\u610F <BALL> \u4EE5\u5F3A\u5316\u3002\n\u6BCF\u4E2A
      <BALL> \u53EF\u88C5\u5907 <MAX_STICKER>\uFF08\u9ED8\u8BA4 4\uFF09\u3002\n-
      \u5DF2\u8D2D\u4E70\u7684 <STICKER> \u4F1A\u663E\u793A\u5728\u53F3\u4FA7\u3002\n-
      \u8981\u51FA\u552E\uFF0C\u70B9\u51FB\u80CC\u5305\u4E2D\u7684\u8BE5\u7269\u54C1\u5E76\u786E\u8BA4\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 704225606094848
    m_Localized: "\u6309\u4F4F <LMB> \u8FDB\u884C\u7784\u51C6\u5E76\u84C4\u529B\uFF0C\u677E\u5F00\u53D1\u5C04\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 704226352680960
    m_Localized: "\u8D34\u7EB8"
    m_Metadata:
      m_Items: []
  - m_Id: 704227103461376
    m_Localized: "- \u5B8C\u6210\u5168\u90E8 8 \u4E2A <LEAGUE> \u5373\u53EF <WIN>\u3002\n-
      \u6BCF\u4E2A <LEAGUE> \u542B 3 \u573A\u53F0\u7403\uFF1A<SMALL>\u3001<BIG>\u3001<PREMIUM>\n-
      <PREMIUM> \u542B\u90E8\u5206\u8D1F\u9762\u6548\u679C\n- \u5B8C\u6210\u4E00\u573A
      <POOL> \u9700\u8FBE\u5230\u5176 <TARGET_SCORE>\n- \u4F60\u53EF <SKIP> <SMALL>
      \u6216 <BIG> \u4EE5\u83B7\u5F97\u989D\u5916\u5956\u52B1"
    m_Metadata:
      m_Items: []
  - m_Id: 704227866824704
    m_Localized: '- <RELICW> gives you passive bonuses during your game.

      -
      Once you purchase a <RELICW>, you can see them on bottom of your table.'
    m_Metadata:
      m_Items: []
  - m_Id: 704229376774144
    m_Localized: "\u53EF\u7528 <RMB> \u53D6\u6D88\u84C4\u529B\u3002"
