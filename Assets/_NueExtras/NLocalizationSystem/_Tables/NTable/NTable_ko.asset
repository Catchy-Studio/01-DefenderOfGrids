      m_Items: []
  - m_Id: 704233143259136
    m_Localized: "- <COSTUME>\uB294 <BALL>\uC758 \uC678\uD615\uACFC \uB2A5\uB825\uC744
      \uBCC0\uACBD\uD569\uB2C8\uB2E4.\n\uAC01 <BALL>\uC740 <COSTUME> 1\uAC1C\uB9CC
      \uCC29\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n- <SPECIAL>\uC740 \uC7A5\uCC29\uB41C
      <BALL>\uC5D0 <UNIQUE> \uD2B9\uC131\uC744 \uBD80\uC5EC\uD569\uB2C8\uB2E4.\n\uAC01
      <BALL>\uC740 \uAC01 <SPECIAL>\uC744 \uD55C \uBC88\uB9CC \uAC00\uC9C8 \uC218
      \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
