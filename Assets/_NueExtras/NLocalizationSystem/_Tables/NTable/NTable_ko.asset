  - m_Id: 703375701692416
    m_Localized: "\uC2B9\uB9AC\uD588\uC2B5\uB2C8\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 703400905265152
    m_Localized: "\uBAA8\uB4E0 \uB9AC\uADF8\uB97C \uC81C\uD328\uD588\uC2B5\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 703438070992896
    m_Localized: "\uBA54\uC778 \uBA54\uB274"
    m_Metadata:
      m_Items: []
  - m_Id: 703651707867136
    m_Localized: "\uD328\uBC30\uD588\uC2B5\uB2C8\uB2E4"
    m_Metadata:
      m_Items: []
  - m_Id: 703824253145088
    m_Localized: "\uB9AC\uADF8\uC5D0\uC11C \uAC15\uB4F1\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 704224020647936
    m_Localized: "\uBAA9\uD45C"
    m_Metadata:
      m_Items: []
  - m_Id: 704224863703040
    m_Localized: "- <STICKER>\uB97C \uC544\uBB34 <BALL>\uC5D0 \uB04C\uC5B4\uB2E4
      \uB193\uC544 \uAC15\uD654\uD558\uC138\uC694.\n\uAC01 <BALL>\uC740 <MAX_STICKER>\uAE4C\uC9C0
      \uC7A5\uCC29\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4(\uAE30\uBCF8 4).\n- \uAD6C\uB9E4\uD55C
      <STICKER>\uB294 \uC6B0\uCE21\uC5D0 \uD45C\uC2DC\uB429\uB2C8\uB2E4.\n- \uD310\uB9E4\uD558\uB824\uBA74
      \uC778\uBCA4\uD1A0\uB9AC\uC5D0\uC11C \uD074\uB9AD \uD6C4 \uD655\uC778\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 704225606094848
    m_Localized: "<LMB>\uB97C \uB20C\uB7EC \uC870\uC900\uD558\uBA70 \uC0F7 \uD30C\uC6CC\uB97C
      \uB192\uC774\uACE0, \uB5BC\uBA74 \uC0F7\uC774 \uB098\uAC11\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 704226352680960
    m_Localized: "\uC2A4\uD2F0\uCEE4"
    m_Metadata:
      m_Items: []
  - m_Id: 704227103461376
    m_Localized: "- 8\uAC1C\uC758 <LEAGUE>\uB97C \uBAA8\uB450 \uC644\uB8CC\uD558\uBA74
      <WIN>\uD569\uB2C8\uB2E4.\n- \uAC01 <LEAGUE>\uC5D0\uB294 <SMALL>, <BIG>, <PREMIUM>
      3\uAC1C\uC758 \uD14C\uC774\uBE14\uC774 \uC788\uC2B5\uB2C8\uB2E4.\n- <PREMIUM>\uC5D0\uB294
      \uC77C\uBD80 \uD328\uB110\uD2F0\uAC00 \uC788\uC2B5\uB2C8\uB2E4.\n- <POOL>\uC744
      \uC644\uB8CC\uD558\uB824\uBA74 \uD574\uB2F9 <TARGET_SCORE>\uB97C \uB118\uACA8\uC57C
      \uD569\uB2C8\uB2E4.\n- \uCD94\uAC00 \uBCF4\uC0C1\uC744 \uC704\uD574 <SMALL>
      \uB610\uB294 <BIG>\uC744 <SKIP>\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 704227866824704
    m_Localized: "- <RELICW>\uB294 \uD50C\uB808\uC774 \uC911 \uC9C0\uC18D \uBCF4\uB108\uC2A4\uB97C
      \uC81C\uACF5\uD569\uB2C8\uB2E4.\n- \uAD6C\uB9E4 \uD6C4 \uD14C\uC774\uBE14 \uD558\uB2E8\uC5D0\uC11C
      \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 704229376774144
    m_Localized: "<RMB>\uB85C \uD30C\uC6CC \uCDA9\uC804\uC744 \uCDE8\uC18C\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 704230119165952
    m_Localized: "\uC870\uC791\uBC95"
    m_Metadata:
      m_Items: []
  - m_Id: 704230886723584
