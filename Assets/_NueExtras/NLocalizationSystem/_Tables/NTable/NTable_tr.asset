  - m_Id: 681739992682496
    m_Localized: "<wave>\u0130\u015Faret Topunu de\u011Fi\u015Ftirmek i\xE7in s\xFCr\xFCkle</wave>"
    m_Metadata:
      m_Items: []
  - m_Id: 682049238716416
    m_Localized: "At\u0131\u015F:"
    m_Metadata:
      m_Items: []
  - m_Id: 682080037490688
    m_Localized: "Yer De\u011Fi\u015Ftirmeler:"
    m_Metadata:
      m_Items: []
  - m_Id: 682120130842624
    m_Localized: "DE\u011E\u0130\u015ET\u0130R"
    m_Metadata:
      m_Items: []
  - m_Id: 682146932445184
    m_Localized: Onayla
    m_Metadata:
      m_Items: []
  - m_Id: 682167488729088
    m_Localized: "\u0130ptal"
    m_Metadata:
      m_Items: []
  - m_Id: 682194030284800
    m_Localized: OYUN
    m_Metadata:
      m_Items: []
  - m_Id: 682212862709760
