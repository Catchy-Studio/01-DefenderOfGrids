  - m_Id: 701537615073280
    m_Localized: Devam Et
    m_Metadata:
      m_Items: []
  - m_Id: 701654912978944
    m_Localized: 'Faiz: <#FFBE20>#interest'
    m_Metadata:
      m_Items: []
  - m_Id: 701655709896704
    m_Localized: "At\u0131\u015F: <#FFBE20>#shot"
    m_Metadata:
      m_Items: []
  - m_Id: 701656443899904
    m_Localized: 'Ekstralar: <#FFBE20>#extra'
    m_Metadata:
      m_Items: []
  - m_Id: 701657161125888
    m_Localized: "\xD6d\xFCl: <#FFBE20>#reward"
    m_Metadata:
      m_Items: []
  - m_Id: 703375701692416
    m_Localized: "Kazand\u0131n"
    m_Metadata:
      m_Items: []
  - m_Id: 703400905265152
    m_Localized: "T\xFCm ligleri ge\xE7tin!"
    m_Metadata:
      m_Items: []
  - m_Id: 703438070992896
    m_Localized: "Ana Men\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 703651707867136
    m_Localized: Kaybettin
    m_Metadata:
      m_Items: []
  - m_Id: 703824253145088
    m_Localized: "Ligden d\xFC\u015Ft\xFCn."
    m_Metadata:
      m_Items: []
  - m_Id: 704224020647936
    m_Localized: Hedef
    m_Metadata:
      m_Items: []
  - m_Id: 704224863703040
    m_Localized: "- Bir <STICKER>'\u0131 herhangi bir <BALL>'a s\xFCr\xFCkleyip b\u0131rak,
      g\xFC\xE7lendir.\nHer <BALL> <MAX_STICKER> ta\u015F\u0131yabilir, varsay\u0131lan
      4.\n- Sat\u0131n al\u0131nan <STICKER> sa\u011Fda g\xF6r\xFCn\xFCr.\n- Birini
      satmak i\xE7in envanterde \xFCzerine t\u0131kla ve onayla."
    m_Metadata:
      m_Items: []
  - m_Id: 704225606094848
    m_Localized: "Hedef almak ve at\u0131\u015F g\xFCc\xFCn\xFC art\u0131rmak i\xE7in
      <LMB>'yi bas\u0131l\u0131 tut. B\u0131rak\u0131nca at\u0131\u015F yapar."
    m_Metadata:
      m_Items: []
  - m_Id: 704226352680960
    m_Localized: Stikerlar
    m_Metadata:
      m_Items: []
  - m_Id: 704227103461376
    m_Localized: "- T\xFCm 8 <LEAGUE>'i tamamla ve <WIN>.\n- Her <LEAGUE> i\xE7inde
      3 bilardo vard\u0131r; <SMALL>, <BIG>, <PREMIUM>\n- <PREMIUM> baz\u0131 negatif
      etkiler i\xE7erir\n- Bir <POOL>'u tamamlamak i\xE7in <TARGET_SCORE>'unu ge\xE7melisin\n-
      Ekstra \xF6d\xFCl i\xE7in <SMALL> veya <BIG>'i <SKIP> edebilirsin"
    m_Metadata:
      m_Items: []
  - m_Id: 704227866824704
    m_Localized: "- <RELICW> sana oyun s\u0131ras\u0131nda pasif bonuslar verir.\n-
      Bir <RELICW> sat\u0131n ald\u0131\u011F\u0131nda, onlar\u0131 masan\u0131n
      alt k\u0131sm\u0131nda g\xF6rebilirsin."
    m_Metadata:
      m_Items: []
  - m_Id: 704229376774144
    m_Localized: "G\xFC\xE7lendirmeyi <RMB> ile iptal edebilirsin."
    m_Metadata:
      m_Items: []
  - m_Id: 704230119165952
    m_Localized: Kontroller
    m_Metadata:
      m_Items: []
  - m_Id: 704230886723584
    m_Localized: Relikler
    m_Metadata:
      m_Items: []
  - m_Id: 704231637504000
    m_Localized: "\xD6\u011Fretici"
    m_Metadata:
      m_Items: []
  - m_Id: 704232384090112
    m_Localized: "Kost\xFCm & \xD6zel"
    m_Metadata:
      m_Items: []
  - m_Id: 704233143259136
    m_Localized: "- <COSTUME>, <BALL>'\u0131n g\xF6r\xFCn\xFC\u015F\xFCn\xFC ve \xF6zelliklerini
      de\u011Fi\u015Ftirir.\nHer <BALL> yaln\u0131zca 1 <COSTUME> ta\u015F\u0131yabilir.\n-
      <SPECIAL>, tak\u0131l\u0131 oldu\u011Fu <BALL>'a <UNIQUE> bir \xF6zellik verir.\nHer
      <BALL> her <SPECIAL>'den yaln\u0131zca bir kez ta\u015F\u0131yabilir."
    m_Metadata:
      m_Items: []
  - m_Id: 704682764259328
    m_Localized: Stikerlar
    m_Metadata:
      m_Items: []
  - m_Id: 705583956611072
    m_Localized: "Sat\u0131ld\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 705713380249600
    m_Localized: Stikerlar
    m_Metadata:
      m_Items: []
  - m_Id: 705752638935040
    m_Localized: Paketler
    m_Metadata:
      m_Items: []
  - m_Id: 705822348267520
    m_Localized: "Sat\u0131ld\u0131"
    m_Metadata:
      m_Items: []
