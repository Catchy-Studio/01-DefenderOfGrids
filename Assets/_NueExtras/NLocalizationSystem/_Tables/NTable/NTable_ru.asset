      m_Items: []
  - m_Id: 704233143259136
    m_Localized: "- <COSTUME> \u043C\u0435\u043D\u044F\u0435\u0442 \u0432\u043D\u0435\u0448\u043D\u0438\u0439
      \u0432\u0438\u0434 \u0438 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
      \u0442\u0432\u043E\u0435\u0433\u043E <BALL>.\n\u041A\u0430\u0436\u0434\u044B\u0439
      <BALL> \u043C\u043E\u0436\u0435\u0442 \u0438\u043C\u0435\u0442\u044C \u0442\u043E\u043B\u044C\u043A\u043E
      1 <COSTUME>.\n- <SPECIAL> \u0434\u0430\u0451\u0442 \u043F\u0440\u0438\u043A\u0440\u0435\u043F\u043B\u0451\u043D\u043D\u043E\u043C\u0443
      <BALL> <UNIQUE> \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u044C.\n\u041A\u0430\u0436\u0434\u044B\u0439
      <BALL> \u043C\u043E\u0436\u0435\u0442 \u0438\u043C\u0435\u0442\u044C \u043A\u0430\u0436\u0434\u0443\u044E
      <SPECIAL> \u043B\u0438\u0448\u044C \u043E\u0434\u0438\u043D \u0440\u0430\u0437."
