      m_Items: []
  - m_Id: 703438070992896
    m_Localized: "\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u043C\u0435\u043D\u044E"
    m_Metadata:
      m_Items: []
  - m_Id: 703651707867136
    m_Localized: "\u0422\u044B \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u043B"
    m_Metadata:
      m_Items: []
  - m_Id: 703824253145088
    m_Localized: "\u0422\u044B \u043F\u043E\u043D\u0438\u0437\u0438\u043B\u0441\u044F
      \u0432 \u043B\u0438\u0433\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 704224020647936
    m_Localized: "\u0426\u0435\u043B\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 704224863703040
    m_Localized: "- \u041F\u0435\u0440\u0435\u0442\u0430\u0449\u0438 <STICKER> \u043D\u0430
      \u043B\u044E\u0431\u043E\u0439 <BALL>, \u0447\u0442\u043E\u0431\u044B \u0443\u0441\u0438\u043B\u0438\u0442\u044C
      \u0435\u0433\u043E.\n\u041A\u0430\u0436\u0434\u044B\u0439 <BALL> \u043C\u043E\u0436\u0435\u0442
      \u0438\u043C\u0435\u0442\u044C <MAX_STICKER> (\u043F\u043E \u0443\u043C\u043E\u043B\u0447\u0430\u043D\u0438\u044E
      4).\n- \u041A\u0443\u043F\u043B\u0435\u043D\u043D\u044B\u0435 <STICKER> \u043F\u043E\u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
      \u0441\u043F\u0440\u0430\u0432\u0430.\n- \u0427\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0434\u0430\u0442\u044C,
      \u043D\u0430\u0436\u043C\u0438 \u043D\u0430 \u043D\u0435\u0433\u043E \u0432
      \u0438\u043D\u0432\u0435\u043D\u0442\u0430\u0440\u0435 \u0438 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 704225606094848
    m_Localized: "\u0423\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439 <LMB>, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0440\u0438\u0446\u0435\u043B\u0438\u0442\u044C\u0441\u044F \u0438 \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0442\u044C
      \u0441\u0438\u043B\u0443 \u0443\u0434\u0430\u0440\u0430. \u041E\u0442\u043F\u0443\u0441\u0442\u0438,
      \u0447\u0442\u043E\u0431\u044B \u0443\u0434\u0430\u0440\u0438\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 704226352680960
    m_Localized: "\u0421\u0442\u0438\u043A\u0435\u0440\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 704227103461376
    m_Localized: "- \u0417\u0430\u0432\u0435\u0440\u0448\u0438 \u0432\u0441\u0435
      8 <LEAGUE>, \u0447\u0442\u043E\u0431\u044B <WIN>.\n- \u0412 \u043A\u0430\u0436\u0434\u043E\u0439
      <LEAGUE> \u0435\u0441\u0442\u044C 3 \u0441\u0442\u043E\u043B\u0430: <SMALL>,
      <BIG>, <PREMIUM>\n- \u0412 <PREMIUM> \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0443\u044E\u0442
      \u043D\u0435\u0433\u0430\u0442\u0438\u0432\u043D\u044B\u0435 \u044D\u0444\u0444\u0435\u043A\u0442\u044B\n-
      \u0427\u0442\u043E\u0431\u044B \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C
      <POOL>, \u043F\u0440\u0435\u0432\u044B\u0441\u044C \u0435\u0433\u043E <TARGET_SCORE>\n-
      \u041C\u043E\u0436\u043D\u043E <SKIP> <SMALL> \u0438\u043B\u0438 <BIG>, \u0447\u0442\u043E\u0431\u044B
      \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
      \u043D\u0430\u0433\u0440\u0430\u0434\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 704227866824704
    m_Localized: "- <RELICW> \u0434\u0430\u044E\u0442 \u043F\u0430\u0441\u0441\u0438\u0432\u043D\u044B\u0435
      \u0431\u043E\u043D\u0443\u0441\u044B \u0432\u043E \u0432\u0440\u0435\u043C\u044F
      \u0438\u0433\u0440\u044B.\n- \u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u043A\u0443\u043F\u043A\u0438
      \u043E\u043D\u0438 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u044E\u0442\u0441\u044F
      \u0432\u043D\u0438\u0437\u0443 \u0441\u0442\u043E\u043B\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 704229376774144
    m_Localized: "\u0417\u0430\u0440\u044F\u0434 \u043C\u043E\u0436\u043D\u043E \u043E\u0442\u043C\u0435\u043D\u0438\u0442\u044C
