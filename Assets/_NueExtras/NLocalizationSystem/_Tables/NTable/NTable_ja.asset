    m_Metadata:
      m_Items: []
  - m_Id: 704227103461376
    m_Localized: "- 8\u3064\u306E<LEAGUE>\u3092\u3059\u3079\u3066\u30AF\u30EA\u30A2\u3057\u3066<WIN>\u3002\n-
      \u5404<LEAGUE>\u306B\u306F<SMALL>\u3001<BIG>\u3001<PREMIUM>\u306E3\u30C6\u30FC\u30D6\u30EB\u304C\u3042\u308A\u307E\u3059\u3002\n-
      <PREMIUM>\u306B\u306F\u30DE\u30A4\u30CA\u30B9\u52B9\u679C\u3042\u308A\u3002\n-
      <POOL>\u3092\u30AF\u30EA\u30A2\u3059\u308B\u306B\u306F<TARGET_SCORE>\u3092\u8D85\u3048\u308B\u5FC5\u8981\u304C\u3042\u308A\u307E\u3059\u3002\n-
      \u8FFD\u52A0\u5831\u916C\u306E\u305F\u3081\u306B<SMALL>\u307E\u305F\u306F<BIG>\u3092<SKIP>\u53EF\u80FD\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 704227866824704
    m_Localized: "- <RELICW>\u306F\u30D7\u30EC\u30A4\u4E2D\u306B\u30D1\u30C3\u30B7\u30D6\u52B9\u679C\u3092\u4ED8\u4E0E\u3057\u307E\u3059\u3002\n-
      \u8CFC\u5165\u5F8C\u3001\u30C6\u30FC\u30D6\u30EB\u4E0B\u90E8\u306B\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
