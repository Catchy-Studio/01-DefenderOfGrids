  - m_Id: 704224863703040
    m_Localized: "- <STICKER>\u3092\u4EFB\u610F\u306E<BALL>\u3078\u30C9\u30E9\u30C3\u30B0&\u30C9\u30ED\u30C3\u30D7\u3057\u3066\u5F37\u5316\u3057\u307E\u3059\u3002\n\u5404<BALL>\u306F<MAX_STICKER>\u307E\u3067\u88C5\u7740\u53EF\u80FD\uFF08\u521D\u671F\u50244\uFF09\u3002\n-
      \u8CFC\u5165\u3057\u305F<STICKER>\u306F\u53F3\u5074\u306B\u8868\u793A\u3002\n-
      \u58F2\u5374\u306F\u30A4\u30F3\u30D9\u30F3\u30C8\u30EA\u3067\u9078\u629E\u3057\u3066\u78BA\u8A8D\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 704225606094848
    m_Localized: "<LMB>\u3092\u62BC\u3057\u7D9A\u3051\u3066\u72D9\u3044\u3001\u30B7\u30E7\u30C3\u30C8\u306E\u529B\u3092\u6E9C\u3081\u307E\u3059\u3002\u96E2\u3057\u3066\u767A\u5C04\u3002"
