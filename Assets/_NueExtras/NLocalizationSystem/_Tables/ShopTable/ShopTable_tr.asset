  m_SharedData: {fileID: 11400000, guid: 69d2579f0a363cb4fa1adcbc39264b9d, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 92334968832
    m_Localized: "Ate\u015F Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 93291270144
    m_Localized: "Hareket ederken ard\u0131nda ate\u015F izi b\u0131rak\u0131r. Ba\u015Fka
      bir top ate\u015F izine de\u011Ferse 1x <BURN> uygular.\nKendini her zaman
      <BURN> yapar.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 94377594880
    m_Localized: "Sekme \xC7arpan"
    m_Metadata:
      m_Items: []
  - m_Id: 95220649984
    m_Localized: "<ON_BOUNCE>, +#Sekme\xC7arpan <MULT>"
    m_Metadata:
      m_Items: []
  - m_Id: 96311169024
    m_Localized: "\xC7elik Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 97175195648
    m_Localized: "Gidilen her mesafe i\xE7in +1 <MULT>. +%1000 <WEIGHT>\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 98265714688
    m_Localized: Cross Sekmer
    m_Metadata:
      m_Items: []
  - m_Id: 99121352704
    m_Localized: "<ON_BOUNCE>, +#Sekme\xC7arpan <MULT>"
    m_Metadata:
      m_Items: []
  - m_Id: 100211871744
    m_Localized: "G\xFC\xE7"
    m_Metadata:
      m_Items: []
  - m_Id: 101071704064
    m_Localized: "<POWER> #Power art\u0131r"
    m_Metadata:
      m_Items: []
  - m_Id: 102128668672
    m_Localized: Uykucu Stiker
    m_Metadata:
      m_Items: []
  - m_Id: 102992695296
    m_Localized: "<ON_POCKET>, bu top art\u0131k masaya d\xF6nmez.\n(<SPECIAL>)"
    m_Metadata:
      m_Items: []
  - m_Id: 104083214336
    m_Localized: "G\xFC\xE7 Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 104951435264
    m_Localized: "<On_BOUNCE>, t\xFCm g\xFCc\xFC bo\u015Falt\u0131r ve puana \xE7evirir.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 106033565696
    m_Localized: "Kaya Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 106876620800
    m_Localized: '+100 <POINT>.

      <BOUNCE_POINT> olmaz.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 107925196800
    m_Localized: Lanetli Stiker
    m_Metadata:
      m_Items: []
  - m_Id: 108789223424
    m_Localized: "<WHILE_ATTACHED>, bu top <BLACK_BALL> olarak say\u0131l\u0131r.\n<ON_POCKET>,
      stikeri yok et.\n(<SPECIAL>)"
    m_Metadata:
      m_Items: []
  - m_Id: 109841993728
    m_Localized: "Alt\u0131n Kost\xFCm"
    m_Metadata:
      m_Items: []
  - m_Id: 110706020352
    m_Localized: '<ON_BOUNCE_WALL>, %20 ihtimalle 1<COIN> kazan.

      <ON_POCKET>,
      5<COIN> kazan.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 111762984960
    m_Localized: "Cep Paras\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 112622817280
    m_Localized: <ON_POCKET>, +#CoinOnPocket<COIN>
    m_Metadata:
      m_Items: []
  - m_Id: 113688170496
    m_Localized: "Ters Kost\xFCm"
    m_Metadata:
      m_Items: []
  - m_Id: 114552197120
    m_Localized: "Top puan\u0131 ile cep puanlar\u0131 tersine \xE7evrilir.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 115617550336
    m_Localized: Mega Puan
    m_Metadata:
      m_Items: []
  - m_Id: 116481576960
    m_Localized: "<POINT> #Point art\u0131r"
    m_Metadata:
      m_Items: []
  - m_Id: 117559513088
    m_Localized: "Soytar\u0131 Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 118415151104
    m_Localized: '<ON_TURN_START> rastgele hareket eder.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 119501475840
    m_Localized: "Pocket \xC7arpan"
    m_Metadata:
      m_Items: []
  - m_Id: 120344530944
    m_Localized: "<ON_POCKET>, +#Pocket\xC7arpan <MULT>"
    m_Metadata:
      m_Items: []
  - m_Id: 121422467072
    m_Localized: "Cep Puan\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 122282299392
    m_Localized: "<POCKET_POINT> #PocketPoint art\u0131r"
    m_Metadata:
      m_Items: []
  - m_Id: 123372818432
    m_Localized: "Bomba Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 124220067840
    m_Localized: "<ON_HIT> K\xFC\xE7\xFCk bir patlama yarat\u0131r. Her 6 vuru\u015Fta
      b\xFCy\xFCk bir patlama olu\u015Fturur.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 125306392576
    m_Localized: "Z\u0131plama"
    m_Metadata:
      m_Items: []
  - m_Id: 126183002112
    m_Localized: "<BOUNCY> #Bounciness art\u0131r"
    m_Metadata:
      m_Items: []
  - m_Id: 127286104064
    m_Localized: "A\u011F\u0131rl\u0131k"
    m_Metadata:
      m_Items: []
  - m_Id: 128154324992
    m_Localized: "<WEIGHT> #A\u011F\u0131rl\u0131k art\u0131r"
    m_Metadata:
      m_Items: []
  - m_Id: 129232261120
    m_Localized: Mega Cep
    m_Metadata:
      m_Items: []
  - m_Id: 130155008000
    m_Localized: "<POCKET_POINT> #PocketPoint art\u0131r"
    m_Metadata:
      m_Items: []
  - m_Id: 131232944128
    m_Localized: "\u015Eansl\u0131 Stiker"
    m_Metadata:
      m_Items: []
  - m_Id: 132126330880
    m_Localized: '<ON_POCKET>, +5 <COIN> ve %20 ihtimalle yok olur.

      (<SPECIAL>)'
    m_Metadata:
      m_Items: []
  - m_Id: 133216849920
    m_Localized: "Buz Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 134106042368
    m_Localized: "<ON_BALL_HIT> 1x <FREEZE> uygula. Hedef topta 3x <FREEZE> varsa
      <SHATTER>. <FREEZE>'e ba\u011F\u0131\u015F\u0131k.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 135200755712
    m_Localized: "Top Puan\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 136098336768
    m_Localized: "<POINT> #Point art\u0131r"
    m_Metadata:
      m_Items: []
  - m_Id: 137222410240
    m_Localized: "Uzay Kost\xFCm\xFC"
    m_Metadata:
      m_Items: []
  - m_Id: 138115796992
    m_Localized: "E\u015Fsiz bir y\xF6r\xFCngesel hareketi vard\u0131r.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 139214704640
    m_Localized: "Cep Alt\u0131n\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 140082925568
    m_Localized: <ON_POCKET>, +#CoinOnPocket<COIN>
    m_Metadata:
      m_Items: []
  - m_Id: 141144084480
    m_Localized: Hedef Stikeri
    m_Metadata:
      m_Items: []
  - m_Id: 141999722496
    m_Localized: '<WHILE_ATTACHED>, 2x <BOUNCE_POINT>

      <ON_POCKET>, stikeri
      yok et.

      (<SPECIAL>)'
    m_Metadata:
      m_Items: []
  - m_Id: 144822489088
    m_Localized: "\xC7ift\xE7i Stikeri"
    m_Metadata:
      m_Items: []
  - m_Id: 145673932800
    m_Localized: "<ON_TURN_END>, sabit kald\u0131ysa +2 <COIN>\n(<SPECIAL>)"
    m_Metadata:
      m_Items: []
  - m_Id: 146764451840
    m_Localized: "\xD6d\xFCl Stikeri"
    m_Metadata:
      m_Items: []
  - m_Id: 147615895552
    m_Localized: '<ON_COLLIDE>, <CUE_BALL> ile, +1 <MULT>.

      (<SPECIAL>)'
    m_Metadata:
      m_Items: []
  - m_Id: 148702220288
    m_Localized: Cep Gezgini
    m_Metadata:
      m_Items: []
  - m_Id: 149557858304
    m_Localized: "<ON_POCKET>, +#Pocket\xC7arpan <MULT>"
    m_Metadata:
      m_Items: []
  - m_Id: 175117946880
    m_Localized: Relik Paketi
    m_Metadata:
      m_Items: []
  - m_Id: 175977779200
    m_Localized: "Rastgele 3 <RELIC> aras\u0131ndan 1 tane se\xE7"
    m_Metadata:
      m_Items: []
  - m_Id: 177026355200
    m_Localized: "Kost\xFCm Paketi"
    m_Metadata:
      m_Items: []
  - m_Id: 177890381824
    m_Localized: "Rastgele 3 <COSTUME_STICKER> aras\u0131ndan 1 tane se\xE7"
    m_Metadata:
      m_Items: []
  - m_Id: 178951540736
    m_Localized: Relik Paketi
    m_Metadata:
      m_Items: []
  - m_Id: 179786207232
    m_Localized: "Rastgele 3 <RELIC> aras\u0131ndan 1 tane se\xE7"
    m_Metadata:
      m_Items: []
  - m_Id: 180864143360
    m_Localized: Relik Paketi
    m_Metadata:
      m_Items: []
  - m_Id: 181694615552
    m_Localized: "Rastgele 3 <RELIC> aras\u0131ndan 1 tane se\xE7"
    m_Metadata:
