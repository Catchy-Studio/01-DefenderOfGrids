    m_Metadata:
      m_Items: []
  - m_Id: 101071704064
    m_Localized: Augmente <POWER> de #Puissance
    m_Metadata:
      m_Items: []
  - m_Id: 102128668672
    m_Localized: Autocollant somnolent
    m_Metadata:
      m_Items: []
  - m_Id: 102992695296
    m_Localized: '<ON_POCKET>, cette bille ne reviendra plus sur la table.

      (<SPECIAL>)'
    m_Metadata:
      m_Items: []
  - m_Id: 104083214336
    m_Localized: Costume de puissance
    m_Metadata:
      m_Items: []
  - m_Id: 104951435264
    m_Localized: "<On_BOUNCE>, d\xE9charge toute la puissance et la convertit en
      points.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 106033565696
    m_Localized: Costume rocheux
    m_Metadata:
      m_Items: []
  - m_Id: 106876620800
    m_Localized: '+100 <POINT>.

      Plus de <BOUNCE_POINT>.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 107925196800
    m_Localized: Autocollant maudit
    m_Metadata:
      m_Items: []
  - m_Id: 108789223424
    m_Localized: "<WHILE_ATTACHED>, cette bille compte comme <BLACK_BALL>.\n<ON_POCKET>,
      d\xE9truit l'autocollant.\n(<SPECIAL>)"
    m_Metadata:
      m_Items: []
  - m_Id: 109841993728
    m_Localized: "Costume dor\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 110706020352
    m_Localized: '<ON_BOUNCE_WALL>, 20 % de chance de gagner 1<COIN>.

      <ON_POCKET>,
      gagne 5<COIN>.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
