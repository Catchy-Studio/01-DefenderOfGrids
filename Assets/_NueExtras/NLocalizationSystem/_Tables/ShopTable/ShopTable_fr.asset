  m_TableData:
  - m_Id: 92334968832
    m_Localized: Costume de feu
    m_Metadata:
      m_Items: []
  - m_Id: 93291270144
    m_Localized: "Laisse une tra\xEEn\xE9e de feu en se d\xE9pla\xE7ant. Si une autre
      bille la touche, applique 1\xD7 <BURN>.\nSubit toujours <BURN>.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 94377594880
    m_Localized: Multiplicateur de rebond
    m_Metadata:
      m_Items: []
  - m_Id: 95220649984
    m_Localized: <ON_BOUNCE>, +#BounceMultiplier <MULT>
    m_Metadata:
      m_Items: []
  - m_Id: 96311169024
    m_Localized: Costume d'acier
    m_Metadata:
      m_Items: []
  - m_Id: 97175195648
    m_Localized: '+1 <MULT> par distance parcourue. +1000 % <WEIGHT>.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 98265714688
    m_Localized: "Rebond crois\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 99121352704
    m_Localized: <ON_BOUNCE>, +#BounceMultiplier <MULT>
    m_Metadata:
      m_Items: []
  - m_Id: 100211871744
