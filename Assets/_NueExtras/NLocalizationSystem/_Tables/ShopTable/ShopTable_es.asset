  - m_Id: 92334968832
    m_Localized: Traje de fuego
    m_Metadata:
      m_Items: []
  - m_Id: 93291270144
    m_Localized: 'Deja un rastro de fuego al moverse. Si otra bola toca el rastro,
      aplica 1x <BURN>.

      Siempre bajo <BURN>.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 94377594880
    m_Localized: Multiplicador de rebote
    m_Metadata:
      m_Items: []
  - m_Id: 95220649984
    m_Localized: <ON_BOUNCE>, +#BounceMultiplier <MULT>
    m_Metadata:
      m_Items: []
  - m_Id: 96311169024
    m_Localized: Traje de acero
    m_Metadata:
      m_Items: []
  - m_Id: 97175195648
    m_Localized: '+1 <MULT> por cada distancia recorrida. +1000% de <WEIGHT>.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 98265714688
    m_Localized: Rebote cruzado
    m_Metadata:
      m_Items: []
