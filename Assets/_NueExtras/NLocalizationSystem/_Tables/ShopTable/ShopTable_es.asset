      m_Items: []
  - m_Id: 104083214336
    m_Localized: Traje de potencia
    m_Metadata:
      m_Items: []
  - m_Id: 104951435264
    m_Localized: '<On_BOUNCE>, descarga toda la potencia y la convierte en puntos.

      (<COSTUME>)'
    m_Metadata:
      m_Items: []
  - m_Id: 106033565696
    m_Localized: Traje rocoso
    m_Metadata:
      m_Items: []
  - m_Id: 106876620800
    m_Localized: "+100 <POINT>.\nNo se obtendr\xE1n <BOUNCE_POINT>.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 107925196800
    m_Localized: Pegatina maldita
    m_Metadata:
      m_Items: []
  - m_Id: 108789223424
    m_Localized: '<WHILE_ATTACHED>, esta bola cuenta como <BLACK_BALL>.

      <ON_POCKET>,
      destruye la pegatina.

      (<SPECIAL>)'
    m_Metadata:
      m_Items: []
  - m_Id: 109841993728
    m_Localized: Traje dorado
    m_Metadata:
      m_Items: []
  - m_Id: 110706020352
    m_Localized: "<ON_BOUNCE_WALL>, 20% de probabilidad de obtener 1<COIN>.\n<ON_POCKET>,
