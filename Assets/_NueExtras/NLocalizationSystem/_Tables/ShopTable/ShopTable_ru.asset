      m_Items: []
  - m_Id: 95220649984
    m_Localized: <ON_BOUNCE>, +#BounceMultiplier <MULT>
    m_Metadata:
      m_Items: []
  - m_Id: 96311169024
    m_Localized: "\u0421\u0442\u0430\u043B\u044C\u043D\u043E\u0439 \u043A\u043E\u0441\u0442\u044E\u043C"
    m_Metadata:
      m_Items: []
  - m_Id: 97175195648
    m_Localized: "+1 <MULT> \u0437\u0430 \u043A\u0430\u0436\u0434\u0443\u044E \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u0443\u044E
      \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u044E. +1000% \u043A <WEIGHT>.\n(<COSTUME>)"
