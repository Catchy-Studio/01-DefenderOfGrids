  m_TableData:
  - m_Id: 92334968832
    m_Localized: "\u041E\u0433\u043D\u0435\u043D\u043D\u044B\u0439 \u043A\u043E\u0441\u0442\u044E\u043C"
    m_Metadata:
      m_Items: []
  - m_Id: 93291270144
    m_Localized: "\u041E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u043E\u0433\u043D\u0435\u043D\u043D\u044B\u0439
      \u0441\u043B\u0435\u0434 \u043F\u0440\u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438.
      \u0415\u0441\u043B\u0438 \u0434\u0440\u0443\u0433\u043E\u0439 \u0448\u0430\u0440
      \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F \u0441\u043B\u0435\u0434\u0430,
      \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442 1x <BURN>
      \u043D\u0430 \u043D\u0435\u0433\u043E.\n\u0412\u0441\u0435\u0433\u0434\u0430
      \u043F\u043E\u0434 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\u043C <BURN>.\n(<COSTUME>)"
    m_Metadata:
      m_Items: []
  - m_Id: 94377594880
    m_Localized: "\u041C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u044C \u043E\u0442\u0441\u043A\u043E\u043A\u0430"
