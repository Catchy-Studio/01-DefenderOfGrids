      m_Items: []
  - m_Id: 719706378240
    m_Localized: Son Rezervler
    m_Metadata:
      m_Items: []
  - m_Id: 720541044736
    m_Localized: "<ON_GAME_END> kalan her <REPLACE> i\xE7in +1 <COIN>"
