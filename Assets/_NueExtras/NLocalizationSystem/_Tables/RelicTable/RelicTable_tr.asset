      m_Items: []
  - m_Id: 725469351936
    m_Localized: "Spot I\u015F\u0131k"
    m_Metadata:
      m_Items: []
  - m_Id: 726329184256
    m_Localized: "<ON_POCKET> (<CUE_BALL> hari\xE7), hi\xE7 <BOUNCE> olmadan, +10x
