    m_Metadata:
      m_Items: []
  - m_Id: 709069623296
    m_Localized: "<ON_GAME_START>, 10 <POINT>\uC758 <NUMBERS_BALL> 1\uAC1C <SPAWN>.\n<NUMBERS_1>
