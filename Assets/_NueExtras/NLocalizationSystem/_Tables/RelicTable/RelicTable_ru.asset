    m_Metadata:
      m_Items: []
  - m_Id: 715914727424
    m_Localized: "\u0418\u0434\u0435\u043D\u0442\u0438\u0444\u0438\u043A\u0430\u0442\u043E\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 716753588224
    m_Localized: <ON_TURN_END> +1 <COIN>
    m_Metadata:
      m_Items: []
  - m_Id: 717797969920
    m_Localized: "\u041A\u043D\u0438\u0433\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 718636830720
    m_Localized: "\u0412\u043A\u043B\u044E\u0447\u0430\u0435\u0442 \u0432\u0442\u043E\u0440\u0443\u044E
      \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044E"
    m_Metadata:
      m_Items: []
  - m_Id: 719706378240
    m_Localized: "\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0440\u0435\u0437\u0435\u0440\u0432\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 720541044736
    m_Localized: "<ON_GAME_END> +1 <COIN> \u0437\u0430 \u043A\u0430\u0436\u0434\u044B\u0439
      \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0439\u0441\u044F <REPLACE>"
