      m_Items: []
  - m_Id: 721614786560
    m_Localized: "\u0427\u0438\u0441\u043B\u0430 IV"
    m_Metadata:
      m_Items: []
  - m_Id: 722462035968
    m_Localized: "<ON_GAME_START>, <SPAWN> 1x <NUMBERS_BALL> \u0441 1000 <POINT>.\n\u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
      <NUMBERS_100>."
    m_Metadata:
      m_Items: []
  - m_Id: 723527389184
    m_Localized: "\u041F\u0440\u0430\u0437\u0434\u043D\u0438\u0447\u043D\u0430\u044F
      \u0448\u0430\u043F\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 724387221504
    m_Localized: "<ON_TURN_START>, \u0434\u0430\u0451\u0442 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u043C\u0443
      \u0448\u0430\u0440\u0443 10 <POINT>\n(<STACKABLE>)"
    m_Metadata:
      m_Items: []
  - m_Id: 725469351936
    m_Localized: "\u041F\u0440\u043E\u0436\u0435\u043A\u0442\u043E\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 726329184256
    m_Localized: "<ON_POCKET> (\u043A\u0440\u043E\u043C\u0435 <CUE_BALL>) \u0431\u0435\u0437
      \u043A\u0430\u043A\u043E\u0433\u043E-\u043B\u0438\u0431\u043E <BOUNCE>, +10\xD7
      <POCKET_POINT>"
    m_Metadata:
      m_Items: []
  - m_Id: 727386148864
    m_Localized: "Golden \u0411\u0435\u043B\u044B\u0439 \u0448\u0430\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 728254369792
    m_Localized: "<ON_POCKET> (\u043A\u0440\u043E\u043C\u0435 <CUE_BALL> \u0438 <BLACK_BALL>),
      \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u0442\u0432\u043E\u0439
      <CUE_BALL> \u0432 <GOLDEN_CUE_BALL>."
    m_Metadata:
      m_Items: []
  - m_Id: 729340694528
    m_Localized: "\u0420\u0430\u0441\u0442\u0435\u043D\u0438\u0435 \u0437\u0430\u043C\u0435\u043D\u044B"
    m_Metadata:
      m_Items: []
