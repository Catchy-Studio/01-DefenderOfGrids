  m_TableData:
  - m_Id: 702346153984
    m_Localized: "\u0422\u043E\u0441\u0442-\u043C\u0430\u0448\u0438\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 703260512256
    m_Localized: "<ON_GAME_START>, \u0431\u0440\u043E\u0441\u044C 2 <TOAST> \u0432
      \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0435 \u043B\u0443\u0437\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 704338448384
    m_Localized: "\u042F\u0434\u0440\u043E \u0447\u0451\u0440\u043D\u043E\u0439 \u0434\u044B\u0440\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 705189892096
    m_Localized: "<ON_POCKET>, \u043F\u0440\u0438\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442
      \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u0435 \u0448\u0430\u0440\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 706242662400
    m_Localized: "\u0410\u0432\u0430\u0440\u0438\u0439\u043D\u044B\u0439 \u043D\u0430\u0431\u043E\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 707127660544
    m_Localized: "\u0415\u0441\u043B\u0438 \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
      <SHOT> \u0442\u044B \u043D\u0435 \u0434\u043E\u0441\u0442\u0438\u0433\u0430\u0435\u0448\u044C
      <TARGET_SCORE>, \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0448\u044C \u0435\u0449\u0451
      \u043E\u0434\u0438\u043D <SHOT> (\u043E\u0434\u0438\u043D \u0440\u0430\u0437).\n\u042D\u0442\u043E\u0442
      <SHOT> \u0442\u0430\u043A\u0436\u0435 \u0434\u0430\u0451\u0442 +2 <MULT>. \u041F\u043E\u0441\u043B\u0435
      \u0441\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043D\u0438\u044F \u043E\u0442\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 708184625152
    m_Localized: "\u0427\u0438\u0441\u043B\u0430 II"
    m_Metadata:
      m_Items: []
  - m_Id: 709069623296
    m_Localized: "<ON_GAME_START>, <SPAWN> 1x <NUMBERS_BALL> \u0441 10 <POINT>.\n\u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
      <NUMBERS_1>."
    m_Metadata:
      m_Items: []
  - m_Id: 710118199296
    m_Localized: "\u0417\u043E\u043B\u043E\u0442\u043E\u0439 \u0442\u0440\u043E\u0444\u0435\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 710973837312
    m_Localized: "<ON_BOUNCE>, +1<COIN>, \u043D\u043E \u0431\u043E\u043B\u044C\u0448\u0435
      \u043D\u0435\u0442 <BOUNCE_POINT>.\n<ON_TURN_END>, +1 <MULT> \u0437\u0430 \u043A\u0430\u0436\u0434\u044B\u0439
      <COIN>."
    m_Metadata:
      m_Items: []
  - m_Id: 712039190528
    m_Localized: "\u0427\u0438\u0441\u043B\u0430 III"
    m_Metadata:
      m_Items: []
  - m_Id: 712886439936
    m_Localized: "<ON_GAME_START>, <SPAWN> 1x <NUMBERS_BALL> \u0441\u043E 100 <POINT>.\n\u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
      <NUMBERS_10>."
    m_Metadata:
      m_Items: []
  - m_Id: 713943404544
    m_Localized: "\u041F\u0440\u043E\u0431\u043E\u0439\u043D\u0438\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 714828402688
