      m_Items: []
  - m_Id: 735191748608
    m_Localized: "\u0427\u0438\u0441\u043B\u0430 I"
    m_Metadata:
      m_Items: []
  - m_Id: 736068358144
    m_Localized: "<ON_GAME_START>, <SPAWN> 1x <NUMBERS_BALL> \u0441 1 <POINT>"
    m_Metadata:
      m_Items: []
  - m_Id: 737154682880
    m_Localized: "\u041C\u0435\u0442\u043A\u0430 \u0410\u0432\u0440\u043E\u0440\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 738018709504
    m_Localized: "<ON_TURN_START>, <HIGHLIGHT> 2 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445
      \u0448\u0430\u0440\u0430.\n(<STACKABLE>)"
    m_Metadata:
      m_Items: []
  - m_Id: 739088257024
    m_Localized: "\u041D\u0435\u0433\u0430\u0442\u0438\u0432\u043D\u044B\u0439 \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0442\u043E\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 739927117824
    m_Localized: "+20% \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u043C\u044B\u0445
      <POINT>. <POINT> \u0442\u0435\u043F\u0435\u0440\u044C \u043C\u043E\u0433\u0443\u0442
      \u0431\u044B\u0442\u044C \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 740992471040
    m_Localized: "\u0422\u0440\u044E\u043A\u043E\u0432\u044B\u0439 \u0443\u0434\u0430\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 741864886272
    m_Localized: "<EACH_TURN>, \u0435\u0441\u043B\u0438 \u0442\u0432\u043E\u0439
      <CUE_BALL> \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0443\u0434\u0430\u0440\u0438\u0442\u0441\u044F
      \u043E \u0441\u0442\u0435\u043D\u0443, \u0442\u043E \u043F\u0440\u0438 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C
      \u043F\u043E\u043F\u0430\u0434\u0430\u043D\u0438\u0438 \u043F\u043E \u0448\u0430\u0440\u0443
      \u043E\u043D \u0434\u0430\u0441\u0442 \u044D\u0442\u043E\u043C\u0443 \u0448\u0430\u0440\u0443
      2 <POINT> (<PERM>)."
    m_Metadata:
      m_Items: []
