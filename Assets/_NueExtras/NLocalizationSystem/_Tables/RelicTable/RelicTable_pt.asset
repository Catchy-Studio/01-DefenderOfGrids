  - m_Id: 702346153984
    m_Localized: "M\xE1quina de torradas"
    m_Metadata:
      m_Items: []
  - m_Id: 703260512256
    m_Localized: "<ON_GAME_START>, arremesse 2 <TOAST> em ca\xE7apas aleat\xF3rias."
    m_Metadata:
      m_Items: []
  - m_Id: 704338448384
    m_Localized: "N\xFAcleo de buraco negro"
    m_Metadata:
      m_Items: []
  - m_Id: 705189892096
    m_Localized: "<ON_POCKET>, atrai bolas pr\xF3ximas."
    m_Metadata:
      m_Items: []
  - m_Id: 706242662400
    m_Localized: "Kit de emerg\xEAncia"
    m_Metadata:
      m_Items: []
  - m_Id: 707127660544
    m_Localized: "Se voc\xEA n\xE3o alcan\xE7ar a <TARGET_SCORE> com sua \xFAltima
      <SHOT>, recebe outra <SHOT> (uma vez).\nEssa <SHOT> tamb\xE9m concede +2 <MULT>.
      Desativa ap\xF3s acionar.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 708184625152
    m_Localized: "N\xFAmeros II"
    m_Metadata:
      m_Items: []
  - m_Id: 709069623296
    m_Localized: '<ON_GAME_START>, <SPAWN> 1x <NUMBERS_BALL> com 10 <POINT>.

      Requer
      <NUMBERS_1>.'
    m_Metadata:
      m_Items: []
  - m_Id: 710118199296
    m_Localized: "Trof\xE9u dourado"
    m_Metadata:
      m_Items: []
  - m_Id: 710973837312
    m_Localized: "<ON_BOUNCE>, +1<COIN>, mas n\xE3o haver\xE1 mais <BOUNCE_POINT>.\n<ON_TURN_END>,
      +1 <MULT> por cada <COIN>."
    m_Metadata:
      m_Items: []
  - m_Id: 712039190528
