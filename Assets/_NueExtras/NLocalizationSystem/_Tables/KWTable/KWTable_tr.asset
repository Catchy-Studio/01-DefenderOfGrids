      m_Items: []
  - m_Id: 225379995865088
    m_Localized: <#ff3643><burn>Yanma</color></burn>
    m_Metadata:
      m_Items: []
  - m_Id: 225380914417664
    m_Localized: "Tur sonunda, top puan\u0131 x <BURN> say\u0131s\u0131 kadar puan
