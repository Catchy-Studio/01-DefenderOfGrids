      m_Items: []
  - m_Id: 225369954701312
    m_Localized: "<#ffd6de><b>\u0130\u015Faret Topu</color></b>"
    m_Metadata:
      m_Items: []
  - m_Id: 225370885836800
    m_Localized: "Bu ana topundur, <WHITE_BALL> olarak da bilinir. <STICKER> tak\u0131lamaz"
    m_Metadata:
      m_Items: []
  - m_Id: 225372035076096
    m_Localized: <#d0eb21>Numbers I</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225373259812864
    m_Localized: "<#ac47ff><b>Kal\u0131c\u0131</color></b>"
    m_Metadata:
      m_Items: []
  - m_Id: 225374417440768
    m_Localized: "<#cd42ff>\xD6zel</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225375344381952
    m_Localized: "<SPECIAL>, tak\u0131l\u0131 oldu\u011Fu topa <UNIQUE> bir \xF6zellik
      verir.\nHer <BALL> her <SPECIAL>'den yaln\u0131zca bir kez ta\u015F\u0131yabilir."
    m_Metadata:
      m_Items: []
  - m_Id: 225376489426944
    m_Localized: "<#36ffd7>Yava\u015F</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225377672220672
    m_Localized: "<#eb2aeb>G\xFC\xE7</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225378842431488
