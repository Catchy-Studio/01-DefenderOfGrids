      m_Items: []
  - m_Id: 225361394126848
    m_Localized: <#f0871f>Birikebilir</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225362287513600
    m_Localized: "Etkileri birden \xE7ok kez birikebilir. <ON_GAME_END>'de s\u0131f\u0131rlan\u0131r."
    m_Metadata:
      m_Items: []
  - m_Id: 225363424169984
    m_Localized: <#519ae8><b>Nadir</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225364544049152
    m_Localized: <#f0b81f>Faiz</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225365445824512
    m_Localized: "Bilardo sonunda elindeki her 5 <sprite name=\"coin\"> i\xE7in +1
