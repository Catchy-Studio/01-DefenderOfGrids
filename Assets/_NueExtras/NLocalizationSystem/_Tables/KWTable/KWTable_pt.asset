      m_Items: []
  - m_Id: 225409850920960
    m_Localized: <#c712e3>Mesa grande</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225410991771648
    m_Localized: <#d4fdff><b><u>Ao quicar</color></b></u>
    m_Metadata:
      m_Items: []
  - m_Id: 225412141010944
    m_Localized: <#d4ffee><b><u>A cada turno</color></b></u>
    m_Metadata:
      m_Items: []
  - m_Id: 225413273473024
    m_Localized: <#ffffff>Bola branca dourada</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225414192025600
    m_Localized: <ON_POCKET>, +5 <COIN> e +100 pontos.
    m_Metadata:
      m_Items: []
  - m_Id: 225415311904768
    m_Localized: <#c5c7bf><b>Comum</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225416435978240
    m_Localized: <#d0eb21>Bola</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225417631354880
    m_Localized: <#d4ffee><b><u>Fim do turno</color></b></u>
    m_Metadata:
      m_Items: []
  - m_Id: 225418843508736
    m_Localized: "<#d4ffee><b><u>Ao enca\xE7apar</color></b></u>"
    m_Metadata:
      m_Items: []
  - m_Id: 225420097605632
    m_Localized: "<rainb>Bola arco-\xEDris</rainb>"
    m_Metadata:
      m_Items: []
  - m_Id: 225421041324032
    m_Localized: Uma <BALL> <SPECIAL>.
    m_Metadata:
      m_Items: []
  - m_Id: 225422203146240
    m_Localized: <#90ff36>Traje</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225423125893120
    m_Localized: '<COSTUME> changes your ball''s visual and properties.

      Each
      <BALL> can only hold 1 <COSTUME>.'
    m_Metadata:
      m_Items: []
  - m_Id: 225424300298240
    m_Localized: "<#d4ffee><b><u>No in\xEDcio da partida</color></b></u>"
    m_Metadata:
      m_Items: []
  - m_Id: 225425445343232
    m_Localized: "<#cf51e8><b>\xC9pico</color></b>"
    m_Metadata:
      m_Items: []
  - m_Id: 225426590388224
    m_Localized: <#7ee851><b>Incomum</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225427768987648
    m_Localized: <#c712e3>Personalizado</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225428951781376
