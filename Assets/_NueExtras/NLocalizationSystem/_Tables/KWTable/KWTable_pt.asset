    m_Metadata:
      m_Items: []
  - m_Id: 225431199928320
    m_Localized: <#d0eb21>Bola numerada</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225432131063808
    m_Localized: <UNIQUE> <BALL> series. Can not be <CUSTOMIZED>
    m_Metadata:
      m_Items: []
  - m_Id: 225433284497408
    m_Localized: "<#d0eb21>N\xFAmeros III</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225434416959488
    m_Localized: "<#eb9e2a>Pontua\xE7\xE3o atual</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225435545227264
    m_Localized: <#eb2005>Fracasso</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225436686077952
