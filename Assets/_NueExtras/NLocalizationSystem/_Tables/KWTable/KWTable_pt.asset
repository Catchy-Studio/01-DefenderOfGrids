    m_Metadata:
      m_Items: []
  - m_Id: 225437835317248
    m_Localized: "<#eb9e2a>Pontua\xE7\xE3o-alvo</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225438753869824
    m_Localized: "Voc\xEA precisa alcan\xE7ar essa pontua\xE7\xE3o antes de ficar
