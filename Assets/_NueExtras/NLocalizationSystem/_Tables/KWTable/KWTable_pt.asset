  m_TableData:
  - m_Id: 225338929434624
    m_Localized: "<#12e316>Vit\xF3ria</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225340116422656
    m_Localized: <#40f5ff>Congelar</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225341014003712
    m_Localized: "<SLOW> 10% por ac\xFAmulo"
    m_Metadata:
      m_Items: []
  - m_Id: 225342146465792
    m_Localized: <#858585><b>Bola preta</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225343048241152
    m_Localized: "<BLACK_BALL> d\xE1 pontos negativos."
    m_Metadata:
      m_Items: []
  - m_Id: 225344163926016
    m_Localized: <#ffa436>Gerar</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225345287999488
    m_Localized: <#e5f257>Substituir</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225346407878656
    m_Localized: <sprite name="coin">
    m_Metadata:
      m_Items: []
  - m_Id: 225347531952128
    m_Localized: <#d4fdff><b><u>Ao atingir uma bola</color></b></u>
    m_Metadata:
      m_Items: []
  - m_Id: 225348651831296
    m_Localized: "<#ffa436>Rel\xEDquia</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225349754933248
    m_Localized: "<#d0eb21>N\xFAmeros II</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225350870618112
    m_Localized: <#5ff257>Elasticidade</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225352019857408
    m_Localized: <#5ff257>Rebote</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225353135542272
    m_Localized: "<#e8a451><b>Lend\xE1rio</color></b>"
    m_Metadata:
      m_Items: []
  - m_Id: 225354251227136
    m_Localized: "<#1898d9>Estilha\xE7ar</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225355136225280
    m_Localized: Concede +1x <MULT> e dobra os pontos da bola. Remove <FREEZE>
    m_Metadata:
      m_Items: []
  - m_Id: 225356277075968
    m_Localized: "<#ffa436>Rel\xEDquia</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225357170462720
    m_Localized: "B\xF4nus passivos que mudam seu estilo de jogo."
    m_Metadata:
      m_Items: []
  - m_Id: 225358273564672
    m_Localized: "<#d0eb21>N\xFAmeros IV</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225359380860928
    m_Localized: <#7aeb2a>Destaque</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225360274247680
    m_Localized: Bolas destacadas ganham pontos em dobro <ON_POCKET>
    m_Metadata:
      m_Items: []
  - m_Id: 225361394126848
    m_Localized: "<#f0871f>Acumul\xE1vel</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225362287513600
    m_Localized: "Pode acumular seus efeitos v\xE1rias vezes. Reinicia em <ON_GAME_END>."
    m_Metadata:
      m_Items: []
  - m_Id: 225363424169984
    m_Localized: <#519ae8><b>Raro</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225364544049152
    m_Localized: <#f0b81f>Juros</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225365445824512
    m_Localized: +1 <sprite name="coin"> a cada 5 <sprite name="coin"> ao final da
      mesa.
    m_Metadata:
      m_Items: []
  - m_Id: 225366557315072
    m_Localized: <#d4d4d4><b>Bola Branca</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225367689777152
    m_Localized: "<#d212e3>Bot\xE3o direito</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225368826433536
    m_Localized: <#d4fdff><b><u>Ao atingir</color></b></u>
    m_Metadata:
      m_Items: []
  - m_Id: 225369954701312
    m_Localized: <#ffd6de><b>Bola branca</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225370885836800
    m_Localized: "Esta \xE9 sua bola principal, tamb\xE9m chamada de <WHITE_BALL>.
      N\xE3o pode equipar <STICKER>"
    m_Metadata:
      m_Items: []
  - m_Id: 225372035076096
    m_Localized: "<#d0eb21>N\xFAmeros I</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225373259812864
    m_Localized: <#ac47ff><b>Permanentemente</color></b>
    m_Metadata:
      m_Items: []
  - m_Id: 225374417440768
    m_Localized: <#cd42ff>Especial</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225375344381952
    m_Localized: "<SPECIAL> concede \xE0 bola equipada um recurso <UNIQUE>.\nCada
      <BALL> s\xF3 pode ter cada <SPECIAL> uma vez."
    m_Metadata:
      m_Items: []
  - m_Id: 225376489426944
    m_Localized: <#36ffd7>Lento</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225377672220672
    m_Localized: <#eb2aeb>Poder</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225378842431488
    m_Localized: <#7e87c4>Peso</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225379995865088
    m_Localized: <#ff3643><burn>Queimadura</color></burn>
    m_Metadata:
      m_Items: []
  - m_Id: 225380914417664
    m_Localized: "No fim do turno, concede pontos iguais aos pontos da bola \xD7
      contagem de <BURN>."
    m_Metadata:
      m_Items: []
  - m_Id: 225382067851264
    m_Localized: "<#d4ffee><b><u>No in\xEDcio do turno</color></b></u>"
    m_Metadata:
      m_Items: []
  - m_Id: 225383225479168
    m_Localized: "<#eb9e2a>Pontua\xE7\xE3o do turno</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 225384370524160
    m_Localized: <#ffa436>Raridade</color>
    m_Metadata:
      m_Items: []
  - m_Id: 225385595260928
