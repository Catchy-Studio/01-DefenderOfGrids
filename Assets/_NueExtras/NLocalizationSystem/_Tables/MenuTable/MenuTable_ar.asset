  - m_Id: 204029284352
    m_Localized: "<b>\u0625\u0634\u0639\u0627\u0631:</b> \u0647\u0630\u0647 \u0627\u0644\u0644\u0639\u0628\u0629
      \u0644\u0627 \u062A\u0632\u0627\u0644 \u0642\u064A\u062F \u0627\u0644\u062A\u0637\u0648\u064A\u0631\u060C
      \u0648\u0642\u062F \u062A\u0643\u0648\u0646 \u0628\u0639\u0636 \u0627\u0644\u0645\u064A\u0632\u0627\u062A
      \u063A\u064A\u0631 \u0645\u0643\u062A\u0645\u0644\u0629 \u0623\u0648 \u062A\u062D\u062A\u0648\u064A
      \u0639\u0644\u0649 \u0623\u062E\u0637\u0627\u0621. \u0625\u0630\u0627 \u0648\u0627\u062C\u0647\u062A
      \u0623\u064A \u0645\u0634\u0643\u0644\u0627\u062A \u0623\u0648 \u0643\u0627\u0646\u062A
      \u0644\u062F\u064A\u0643 \u0645\u0644\u0627\u062D\u0638\u0627\u062A\u060C \u0646\u062D\u0628
      \u0623\u0646 \u0646\u0633\u0645\u0639 \u0645\u0646\u0643!"
